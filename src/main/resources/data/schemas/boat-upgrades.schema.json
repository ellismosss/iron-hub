{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Sailing boat-upgrade catalog (ported from IEarnSolo/boat-upgrades at the plugin-hub pin, BSD-2)",
	"type": "object",
	"required": ["version", "source", "parts", "upgrades", "detection"],
	"additionalProperties": false,
	"properties": {
		"version": {"type": "integer", "minimum": 1},
		"source": {"type": "string", "minLength": 1},
		"parts": {
			"type": "array",
			"minItems": 20,
			"items": {
				"type": "object",
				"required": ["key", "name", "kind", "benefit", "raftExcluded"],
				"additionalProperties": false,
				"properties": {
					"key": {"type": "string", "minLength": 1},
					"name": {"type": "string", "minLength": 1},
					"kind": {"enum": ["core", "facility"]},
					"benefit": {"type": "string", "minLength": 1},
					"raftExcluded": {"type": "boolean"}
				}
			}
		},
		"upgrades": {
			"type": "array",
			"minItems": 90,
			"items": {
				"type": "object",
				"required": ["id", "part", "boatType", "tier", "name", "page",
					"sailing", "construction", "reqs", "schematic", "materials"],
				"additionalProperties": false,
				"properties": {
					"id": {"type": "string", "pattern": "^[a-z0-9_]+_(all|b[0-2])_t[0-9]$"},
					"part": {"type": "string", "minLength": 1},
					"boatType": {"type": "integer", "minimum": -1, "maximum": 2},
					"tier": {"type": "integer", "minimum": 0, "maximum": 6},
					"name": {"type": "string", "minLength": 1},
					"page": {"type": "string", "minLength": 1},
					"sailing": {"type": "integer", "minimum": 1, "maximum": 99},
					"construction": {"type": "integer", "minimum": 1, "maximum": 99},
					"reqs": {"type": "array", "items": {"type": "string", "minLength": 1}},
					"schematic": {"type": ["string", "null"]},
					"materials": {
						"type": "array",
						"minItems": 1,
						"items": {
							"type": "object",
							"required": ["name", "itemId", "qty"],
							"additionalProperties": false,
							"properties": {
								"name": {"type": "string", "minLength": 1},
								"itemId": {"type": "integer", "minimum": 1},
								"qty": {"type": "integer", "minimum": 1}
							}
						}
					}
				}
			}
		},
		"detection": {
			"type": "object",
			"required": ["facilities", "schematics"],
			"additionalProperties": false,
			"properties": {
				"facilities": {
					"type": "array",
					"minItems": 30,
					"items": {
						"type": "object",
						"required": ["part", "tier", "objectIds"],
						"additionalProperties": false,
						"properties": {
							"part": {"type": "string", "minLength": 1},
							"tier": {"type": "integer", "minimum": 0, "maximum": 6},
							"objectIds": {"type": "array", "minItems": 1,
								"items": {"type": "integer", "minimum": 1}}
						}
					}
				},
				"schematics": {
					"type": "array",
					"minItems": 10,
					"maxItems": 10,
					"items": {
						"type": "object",
						"required": ["slug", "name", "upgrade", "varbit"],
						"additionalProperties": false,
						"properties": {
							"slug": {"type": "string", "pattern": "^[a-z0-9_]+$"},
							"name": {"type": "string", "minLength": 1},
							"upgrade": {"type": "string", "minLength": 1},
							"varbit": {"type": "integer", "minimum": 1}
						}
					}
				}
			}
		}
	}
}
