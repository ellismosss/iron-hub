{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Iron Hub herb patch locations",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "patches"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "patches": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "location",
          "regionId",
          "varbit"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "location": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "x",
              "y",
              "plane"
            ],
            "properties": {
              "x": {
                "type": "integer"
              },
              "y": {
                "type": "integer"
              },
              "plane": {
                "type": "integer",
                "minimum": 0,
                "maximum": 3
              }
            }
          },
          "regionId": {
            "type": "integer",
            "minimum": 1
          },
          "varbit": {
            "enum": [
              "A",
              "B",
              "C",
              "D",
              "E",
              "F",
              "G",
              "H",
              "I"
            ]
          }
        }
      }
    }
  }
}