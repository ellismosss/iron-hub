{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Achievement diary tasks, requirements and rewards",
	"type": "object",
	"required": ["source", "generated", "regions"],
	"additionalProperties": false,
	"properties": {
		"source": {"type": "string"},
		"generated": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
		"regions": {
			"type": "array",
			"minItems": 12,
			"maxItems": 12,
			"items": {
				"type": "object",
				"required": ["name", "tiers"],
				"additionalProperties": false,
				"properties": {
					"name": {"type": "string", "minLength": 1},
					"tiers": {
						"type": "array",
						"minItems": 4,
						"maxItems": 4,
						"items": {
							"type": "object",
							"required": ["tier", "tasks", "rewards"],
							"additionalProperties": false,
							"properties": {
								"tier": {"enum": ["Easy", "Medium", "Hard", "Elite"]},
								"tasks": {
									"type": "array",
									"minItems": 5,
									"items": {
										"type": "object",
										"required": ["task", "reqs"],
										"oneOf": [
											{"required": ["varp", "bit"]},
											{"required": ["varbit", "min"]}
										],
										"additionalProperties": false,
										"properties": {
											"task": {"type": "string", "minLength": 1},
											"note": {"type": "string"},
											"varp": {"type": "integer", "minimum": 0},
											"bit": {"type": "integer", "minimum": 0, "maximum": 31},
											"varbit": {"type": "integer", "minimum": 0},
											"min": {"type": "integer", "minimum": 1},
											"reqs": {
												"type": "array",
												"items": {
													"type": "object",
													"required": ["text"],
													"additionalProperties": false,
													"properties": {
														"text": {"type": "string", "minLength": 1},
														"req": {"type": "string", "minLength": 1}
													}
												}
											}
										}
									}
								},
								"rewards": {
									"type": "array",
									"minItems": 1,
									"items": {"type": "string", "minLength": 1}
								}
							}
						}
					}
				}
			}
		}
	}
}
