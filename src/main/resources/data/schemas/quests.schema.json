{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Quest actions for the goal engine",
	"type": "object",
	"required": [
		"source",
		"generated",
		"quests"
	],
	"additionalProperties": false,
	"properties": {
		"source": {
			"type": "string"
		},
		"generated": {
			"type": "string",
			"pattern": "^\\d{4}-\\d{2}-\\d{2}$"
		},
		"quests": {
			"type": "array",
			"minItems": 150,
			"items": {
				"type": "object",
				"required": [
					"name",
					"minutes",
					"qp",
					"order",
					"reqs",
					"xp"
				],
				"additionalProperties": false,
				"properties": {
					"name": {
						"type": "string",
						"minLength": 1
					},
					"enumName": {
						"type": [
							"string",
							"null"
						]
					},
					"minutes": {
						"type": "integer",
						"minimum": 0
					},
					"qp": {
						"type": "integer",
						"minimum": 0
					},
					"order": {
						"type": "integer",
						"minimum": -1
					},
					"reqs": {
						"type": "array",
						"items": {
							"type": "string",
							"minLength": 1
						}
					},
					"xp": {
						"type": "object",
						"additionalProperties": {
							"type": "integer",
							"minimum": 0
						}
					},
					"difficulty": {
						"enum": [
							"Novice",
							"Intermediate",
							"Experienced",
							"Master",
							"Grandmaster",
							"Special"
						]
					},
					"miniquest": {
						"type": "boolean"
					}
				}
			}
		}
	}
}
