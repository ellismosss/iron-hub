{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Iron Hub recommended equipment (wiki tables, offline)",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "source", "activities"],
  "properties": {
    "$schema": {"type": "string"},
    "version": {"type": "integer", "minimum": 1},
    "source": {"type": "string"},
    "activities": {
      "type": "array",
      "minItems": 400,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["page", "slots"],
        "properties": {
          "page": {"type": "string", "minLength": 1},
          "style": {"type": "string"},
          "slots": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["name"],
                "properties": {
                  "name": {"type": "string", "minLength": 1},
                  "itemId": {"type": "integer", "minimum": 0}
                }
              }
            }
          }
        }
      }
    }
  }
}
