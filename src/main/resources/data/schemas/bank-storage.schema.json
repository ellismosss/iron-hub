{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Dedicated-storage item catalog (ported from mcgeer/WastedBankSpace at the plugin-hub pin, BSD-2)",
	"type": "object",
	"required": ["version", "source", "locations"],
	"additionalProperties": false,
	"properties": {
		"version": {"type": "integer", "minimum": 1},
		"source": {"type": "string", "minLength": 1},
		"locations": {
			"type": "array",
			"minItems": 21,
			"maxItems": 21,
			"items": {
				"type": "object",
				"required": ["id", "name", "items"],
				"additionalProperties": false,
				"properties": {
					"id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
					"name": {"type": "string", "minLength": 1},
					"items": {
						"type": "array",
						"minItems": 1,
						"items": {
							"type": "object",
							"required": ["id", "name"],
							"additionalProperties": false,
							"properties": {
								"id": {"type": "integer", "minimum": 1},
								"name": {"type": "string", "minLength": 1},
								"bis": {"type": "boolean"}
							}
						}
					}
				}
			}
		}
	}
}
