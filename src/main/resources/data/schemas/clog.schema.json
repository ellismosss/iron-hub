{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Collection-log activities, drop rates and slots (from Log Adviser, BSD-2)",
	"type": "object",
	"required": [
		"source",
		"generated",
		"activities",
		"slots",
		"aliases",
		"chatNames"
	],
	"additionalProperties": false,
	"properties": {
		"source": {
			"type": "string"
		},
		"generated": {
			"type": "string",
			"pattern": "^\\d{4}-\\d{2}-\\d{2}$"
		},
		"activities": {
			"type": "array",
			"minItems": 200,
			"items": {
				"type": "object",
				"required": [
					"index",
					"name",
					"perHour",
					"extraTimeFirst",
					"category",
					"reqs",
					"items"
				],
				"additionalProperties": false,
				"properties": {
					"index": {
						"type": "integer",
						"minimum": 1
					},
					"name": {
						"type": "string",
						"minLength": 1
					},
					"perHour": {
						"type": "number",
						"minimum": 0
					},
					"extraTimeFirst": {
						"type": "number",
						"minimum": 0
					},
					"category": {
						"enum": [
							"combat",
							"minigame",
							"miscellaneous"
						]
					},
					"reqs": {
						"type": "array",
						"items": {
							"type": "string",
							"pattern": "^(skill|quest):"
						}
					},
					"items": {
						"type": "array",
						"minItems": 1,
						"items": {
							"type": "object",
							"required": [
								"itemId",
								"name",
								"requiresPrevious",
								"exact",
								"independent",
								"attempts"
							],
							"additionalProperties": false,
							"properties": {
								"itemId": {
									"type": "integer",
									"minimum": 1
								},
								"name": {
									"type": "string",
									"minLength": 1
								},
								"requiresPrevious": {
									"type": "boolean"
								},
								"exact": {
									"type": "boolean"
								},
								"independent": {
									"type": "boolean"
								},
								"attempts": {
									"type": "number",
									"minimum": 0
								}
							}
						}
					}
				}
			}
		},
		"slots": {
			"type": "array",
			"minItems": 1000,
			"items": {
				"type": "object",
				"required": [
					"itemId",
					"name"
				],
				"additionalProperties": false,
				"properties": {
					"itemId": {
						"type": "integer",
						"minimum": 1
					},
					"name": {
						"type": "string",
						"minLength": 1
					}
				}
			}
		},
		"aliases": {
			"type": "array",
			"items": {
				"type": "object",
				"required": [
					"alt",
					"canonical"
				],
				"additionalProperties": false,
				"properties": {
					"alt": {
						"type": "integer",
						"minimum": 1
					},
					"canonical": {
						"type": "integer",
						"minimum": 1
					}
				}
			}
		},
		"chatNames": {
			"type": "array",
			"items": {
				"type": "object",
				"required": [
					"name",
					"itemId"
				],
				"additionalProperties": false,
				"properties": {
					"name": {
						"type": "string",
						"minLength": 1
					},
					"itemId": {
						"type": "integer",
						"minimum": 1
					}
				}
			}
		}
	}
}
