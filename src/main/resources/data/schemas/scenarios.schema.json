{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Iron Hub loadout scenarios",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "scenarios"],
  "properties": {
    "$schema": {"type": "string"},
    "version": {"type": "integer", "minimum": 1},
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "style"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
          "name": {"type": "string", "minLength": 1},
          "style": {"enum": ["Melee", "Range", "Mage"]},
          "notes": {"type": "string"}
        }
      }
    }
  }
}
