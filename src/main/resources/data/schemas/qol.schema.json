{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Iron Hub QoL checklist data pack",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "unlocks"],
  "properties": {
    "$schema": {"type": "string"},
    "version": {"type": "integer", "minimum": 1},
    "unlocks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "itemIds", "requirements"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
          "name": {"type": "string", "minLength": 1},
          "itemIds": {"type": "array", "minItems": 1, "items": {"type": "integer", "minimum": 1}},
          "requirements": {"type": "array", "items": {"type": "string"}},
          "benefit": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
