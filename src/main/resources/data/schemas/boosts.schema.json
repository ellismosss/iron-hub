{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Iron Hub temporary skill boosts",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "boosts"],
  "properties": {
    "$schema": {"type": "string"},
    "version": {"type": "integer", "minimum": 1},
    "boosts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "skills", "boost", "gate"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "skills": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "boost": {"type": "integer", "minimum": 1},
          "invisible": {"type": "boolean"},
          "gate": {"type": "string", "pattern": "^(skill|skillb|quest|item|itemx|unlock|kc|any):"}
        }
      }
    }
  }
}
