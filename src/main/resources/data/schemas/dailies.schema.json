{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Iron Hub dailies data pack",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "dailies"],
  "properties": {
    "$schema": {"type": "string"},
    "version": {"type": "integer", "minimum": 1},
    "dailies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "reset", "location", "requirements", "detection"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
          "name": {"type": "string", "minLength": 1},
          "reset": {"enum": ["daily", "weekly", "growth"]},
          "location": {
            "type": "object",
            "additionalProperties": false,
            "required": ["x", "y", "plane"],
            "properties": {
              "x": {"type": "integer"},
              "y": {"type": "integer"},
              "plane": {"type": "integer", "minimum": 0, "maximum": 3}
            }
          },
          "requirements": {"type": "array", "items": {"type": "string"}},
          "scaling": {"type": "string"},
          "detection": {"enum": ["manual", "varbit", "chat"]}
        }
      }
    }
  }
}
