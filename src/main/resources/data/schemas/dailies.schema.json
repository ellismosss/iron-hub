{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Iron Hub dailies data pack",
  "type": "object",
  "additionalProperties": false,
  "required": ["source", "generated", "dailies"],
  "properties": {
    "$schema": {"type": "string"},
    "source": {"type": "string"},
    "generated": {"type": "string"},
    "dailies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "icon", "where", "reset", "point", "reqs", "detection", "tiers", "bring"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
          "name": {"type": "string", "minLength": 1},
          "icon": {"type": "integer", "minimum": 1},
          "where": {"type": "string", "minLength": 1},
          "reset": {"enum": ["daily", "rolling7"]},
          "point": {
            "type": "object",
            "additionalProperties": false,
            "required": ["x", "y", "plane"],
            "properties": {
              "x": {"type": "integer"},
              "y": {"type": "integer"},
              "plane": {"type": "integer", "minimum": 0, "maximum": 3}
            }
          },
          "reqs": {"type": "array", "items": {"type": "string"}},
          "detection": {
            "type": "object",
            "additionalProperties": false,
            "required": ["mode"],
            "properties": {
              "mode": {"enum": ["flag", "count", "rolling7", "manual"]},
              "varbit": {"type": "integer", "minimum": 1},
              "chat": {"type": "string", "minLength": 1}
            },
            "allOf": [
              {
                "comment": "Only a manual event may omit its varbit — every other mode reads one.",
                "if": {"properties": {"mode": {"not": {"const": "manual"}}}},
                "then": {"required": ["varbit"]}
              },
              {
                "comment": "A manual event has no flag to read, so it must not claim one.",
                "if": {"properties": {"mode": {"const": "manual"}}},
                "then": {"not": {"required": ["varbit"]}}
              }
            ]
          },
          "tiers": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["qty"],
              "properties": {
                "req": {"type": "string", "minLength": 1},
                "qty": {"type": "integer", "minimum": 1}
              }
            }
          },
          "bring": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["label", "per"],
              "properties": {
                "label": {"type": "string", "minLength": 1},
                "per": {"type": "integer", "minimum": 1},
                "itemIds": {
                  "type": "array",
                  "minItems": 1,
                  "items": {"type": "integer", "minimum": 1}
                }
              }
            }
          },
          "travel": {"type": "string", "minLength": 1},
          "note": {"type": "string", "minLength": 1},
          "optOut": {"type": "boolean"},
          "warning": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
