{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Collection log ranks (wiki Collection log#Ranks)",
	"type": "object",
	"required": ["source", "generated", "totalSlots", "ranks"],
	"additionalProperties": false,
	"properties": {
		"source": {
			"type": "string"
		},
		"generated": {
			"type": "string",
			"pattern": "^\\d{4}-\\d{2}-\\d{2}$"
		},
		"totalSlots": {
			"type": "integer",
			"minimum": 1000
		},
		"ranks": {
			"type": "array",
			"minItems": 9,
			"items": {
				"type": "object",
				"required": ["name", "slots", "itemId"],
				"additionalProperties": false,
				"properties": {
					"name": {
						"type": "string",
						"minLength": 3
					},
					"slots": {
						"type": "integer",
						"minimum": 1
					},
					"itemId": {
						"type": "integer",
						"minimum": 1
					},
					"percentOfTotal": {
						"type": "number",
						"exclusiveMinimum": 0,
						"maximum": 1
					},
					"roundDown": {
						"type": "integer",
						"minimum": 1
					}
				}
			}
		}
	}
}
