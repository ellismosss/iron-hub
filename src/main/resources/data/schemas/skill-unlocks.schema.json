{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Per-level skill unlocks (wiki Level up table pages)",
	"type": "object",
	"required": ["source", "generated", "skills"],
	"additionalProperties": false,
	"properties": {
		"source": {
			"type": "string"
		},
		"generated": {
			"type": "string",
			"pattern": "^\\d{4}-\\d{2}-\\d{2}$"
		},
		"skills": {
			"type": "object",
			"required": ["Farming", "Herblore"],
			"additionalProperties": {
				"type": "object",
				"minProperties": 40,
				"propertyNames": {
					"pattern": "^[1-9][0-9]?$"
				},
				"additionalProperties": {
					"type": "array",
					"minItems": 1,
					"items": {
						"type": "string",
						"minLength": 3
					}
				}
			}
		}
	}
}
