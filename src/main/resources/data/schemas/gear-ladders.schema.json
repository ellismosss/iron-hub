{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Iron Hub gear progression ladders",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "styles"],
  "properties": {
    "$schema": {"type": "string"},
    "version": {"type": "integer", "minimum": 1},
    "styles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["style", "slots"],
        "properties": {
          "style": {"enum": ["Melee", "Range", "Mage"]},
          "slots": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["slot", "ladder"],
              "properties": {
                "slot": {"type": "string", "minLength": 1},
                "ladder": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["itemId", "name", "requirements"],
                    "properties": {
                      "itemId": {"type": "integer", "minimum": 1},
                      "name": {"type": "string", "minLength": 1},
                      "requirements": {"type": "array", "items": {"type": "string"}}
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
