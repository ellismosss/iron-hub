{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Training method ladders for the goal engine",
	"type": "object",
	"required": [
		"source",
		"generated",
		"skills"
	],
	"additionalProperties": false,
	"properties": {
		"source": {
			"type": "string"
		},
		"generated": {
			"type": "string",
			"pattern": "^\\d{4}-\\d{2}-\\d{2}$"
		},
		"skills": {
			"type": "array",
			"minItems": 24,
			"maxItems": 24,
			"items": {
				"type": "object",
				"required": [
					"skill",
					"methods"
				],
				"additionalProperties": false,
				"properties": {
					"skill": {
						"type": "string",
						"minLength": 1
					},
					"methods": {
						"type": "array",
						"minItems": 1,
						"items": {
							"type": "object",
							"required": [
								"id",
								"name",
								"startXp",
								"rate",
								"style",
								"source"
							],
							"additionalProperties": false,
							"properties": {
								"id": {
									"type": "string",
									"minLength": 1
								},
								"name": {
									"type": "string",
									"minLength": 1
								},
								"startXp": {
									"type": "integer",
									"minimum": 0
								},
								"rate": {
									"type": "integer",
									"minimum": 0
								},
								"req": {
									"type": "string",
									"minLength": 1
								},
								"style": {
									"enum": [
										"active",
										"semi",
										"afk",
										"daily"
									]
								},
								"origin": {
									"enum": [
										"curated",
										"wiki"
									]
								},
								"source": {
									"type": "string",
									"minLength": 1
								},
								"xpEach": {
									"type": "number",
									"exclusiveMinimum": 0
								},
								"inputs": {
									"type": "array",
									"minItems": 1,
									"items": {
										"type": "object",
										"required": [
											"itemId",
											"qty",
											"name"
										],
										"additionalProperties": false,
										"properties": {
											"itemId": {
												"type": "integer",
												"minimum": 1
											},
											"qty": {
												"type": "integer",
												"minimum": 1
											},
											"name": {
												"type": "string",
												"minLength": 1
											}
										}
									}
								}
							}
						}
					},
					"bonuses": {
						"type": "array",
						"items": {
							"type": "object",
							"required": [
								"originSkill",
								"bonusSkill",
								"startXp",
								"endXp",
								"ratio"
							],
							"additionalProperties": false,
							"properties": {
								"originSkill": {
									"type": "string"
								},
								"bonusSkill": {
									"type": "string"
								},
								"startXp": {
									"type": "integer",
									"minimum": 0
								},
								"endXp": {
									"type": "integer",
									"minimum": 0
								},
								"ratio": {
									"type": "number",
									"exclusiveMinimum": 0
								}
							}
						}
					}
				}
			}
		}
	}
}