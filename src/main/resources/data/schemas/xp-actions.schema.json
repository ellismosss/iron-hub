{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Per-action xp fingerprints from the wiki skill calculators",
	"type": "object",
	"required": [
		"source",
		"generated",
		"skills"
	],
	"additionalProperties": false,
	"properties": {
		"$schema": {
			"type": "string"
		},
		"source": {
			"type": "string"
		},
		"generated": {
			"type": "string",
			"pattern": "^\\d{4}-\\d{2}-\\d{2}$"
		},
		"skills": {
			"type": "array",
			"minItems": 15,
			"items": {
				"type": "object",
				"required": [
					"skill",
					"actions"
				],
				"additionalProperties": false,
				"properties": {
					"skill": {
						"type": "string",
						"minLength": 1
					},
					"actions": {
						"type": "array",
						"minItems": 1,
						"items": {
							"type": "object",
							"required": [
								"name",
								"level",
								"xp"
							],
							"additionalProperties": false,
							"properties": {
								"name": {
									"type": "string",
									"minLength": 1
								},
								"level": {
									"type": "integer",
									"minimum": 1,
									"maximum": 99
								},
								"xp": {
									"type": "number",
									"exclusiveMinimum": 0
								},
								"type": {
									"type": [
										"string",
										"null"
									]
								}
							}
						}
					}
				}
			}
		}
	}
}
