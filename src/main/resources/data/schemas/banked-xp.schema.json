{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Iron Hub banked-XP data pack",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "entries"],
  "properties": {
    "$schema": {"type": "string"},
    "version": {"type": "integer", "minimum": 1},
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["skill", "method", "itemId", "name", "xpEach"],
        "properties": {
          "skill": {"type": "string", "pattern": "^[A-Za-z]+$"},
          "method": {"type": "string", "minLength": 1},
          "itemId": {"type": "integer", "minimum": 1},
          "name": {"type": "string", "minLength": 1},
          "xpEach": {"type": "number", "exclusiveMinimum": 0}
        }
      }
    }
  }
}
