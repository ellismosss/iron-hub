{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Iron Hub banked-XP data pack",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "entries"],
  "properties": {
    "$schema": {"type": "string"},
    "source": {"type": "string"},
    "generated": {"type": "string"},
    "version": {"type": "integer", "minimum": 1},
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["skill", "method", "activity", "itemId", "name", "xpEach"],
        "properties": {
          "skill": {"type": "string", "pattern": "^[A-Za-z]+$"},
          "method": {"type": "string", "minLength": 1},
          "activity": {"type": "string", "pattern": "^[A-Za-z0-9_]+$"},
          "itemId": {"type": "integer", "minimum": 1},
          "name": {"type": "string", "minLength": 1},
          "xpEach": {"type": "number", "exclusiveMinimum": 0},
          "level": {"type": "integer", "minimum": 2, "maximum": 99},
          "secondaries": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["itemId", "qty"],
              "properties": {
                "itemId": {"type": "integer", "minimum": 1},
                "qty": {"type": "number", "exclusiveMinimum": 0}
              }
            }
          },
          "outputId": {"type": "integer", "minimum": 1},
          "outputQty": {"type": "number", "exclusiveMinimum": 0}
        }
      }
    },
    "modifiers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["skill", "name", "type", "value"],
        "properties": {
          "skill": {"type": "string", "pattern": "^[A-Za-z]+$"},
          "name": {"type": "string", "minLength": 1},
          "type": {"enum": ["multiplier", "additive"]},
          "value": {"type": "number", "exclusiveMinimum": 0},
          "appliesTo": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "pattern": "^[A-Za-z0-9_]+$"}
          },
          "appliesToAll": {"type": "boolean"},
          "ignores": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "pattern": "^[A-Za-z0-9_]+$"}
          },
          "exclusiveGroup": {"type": "string", "pattern": "^[a-z-]+$"}
        }
      }
    }
  }
}
