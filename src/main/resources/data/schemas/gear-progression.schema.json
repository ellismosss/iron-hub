{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Iron Hub gear progression chart",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "phases"],
  "properties": {
    "$schema": {"type": "string"},
    "version": {"type": "integer", "minimum": 1},
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["phase", "name", "groups"],
        "properties": {
          "phase": {"type": "integer", "minimum": 1},
          "name": {"type": "string", "minLength": 1},
          "groups": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["label", "items"],
              "properties": {
                "label": {"type": "string", "minLength": 1},
                "items": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["name", "categories", "requirements"],
                    "properties": {
                      "name": {"type": "string", "minLength": 1},
                      "itemId": {"type": "integer", "minimum": 1},
                      "iconItemId": {"type": "integer", "minimum": 1},
                      "iconFile": {"type": "string", "minLength": 1},
                      "exact": {"type": "boolean"},
                      "implies": {
                        "type": "array",
                        "minItems": 1,
                        "items": {"type": "string", "minLength": 1}
                      },
                      "categories": {
                        "type": "array",
                        "minItems": 1,
                        "items": {"enum": ["melee", "ranged", "magic", "utility", "poh", "boat"]}
                      },
                      "requirements": {
                        "type": "array",
                        "items": {"type": "string", "minLength": 1}
                      },
                      "wiki": {"type": "string", "minLength": 1}
                    },
                    "oneOf": [
                      {"required": ["itemId"], "not": {"required": ["iconItemId"]}},
                      {"required": ["iconItemId"], "not": {"required": ["itemId"]}}
                    ]
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
