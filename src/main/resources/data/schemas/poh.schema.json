{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Useful POH progression (wiki Infobox Construction per tier; curation per Guide:POH_Progression_&_Layout_Guide)",
	"type": "object",
	"required": ["version", "sources", "spaces"],
	"additionalProperties": false,
	"properties": {
		"version": {"type": "integer", "minimum": 1},
		"sources": {"type": "object"},
		"spaces": {
			"type": "array",
			"minItems": 12,
			"items": {
				"type": "object",
				"required": ["id", "name", "tiers"],
				"additionalProperties": false,
				"properties": {
					"id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
					"name": {"type": "string", "minLength": 1},
					"room": {"type": "string"},
					"icon": {"type": "integer", "minimum": 0},
					"tiers": {
						"type": "array",
						"minItems": 1,
						"items": {
							"type": "object",
							"required": ["id", "name", "page", "level", "reqs", "objectIds"],
							"additionalProperties": false,
							"properties": {
								"id": {"type": "string", "pattern": "^[a-z0-9_]+:[a-z0-9_]+$"},
								"name": {"type": "string", "minLength": 1},
								"page": {"type": "string", "minLength": 1},
								"level": {"type": "integer", "minimum": 1, "maximum": 99},
								"reqs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
								"objectIds": {"type": "array", "minItems": 1, "items": {"type": "integer", "minimum": 1}},
								"icon": {"type": "integer", "minimum": 0}
							}
						}
					}
				}
			}
		}
	}
}
