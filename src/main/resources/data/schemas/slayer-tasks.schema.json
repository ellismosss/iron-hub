{
 "$schema": "http://json-schema.org/draft-07/schema#",
 "title": "Slayer suite pack: task catalog, master tables, unlocks (core Task.java + wiki + Slayer Simplified + Turael Skipping, all BSD-2)",
 "type": "object",
 "required": [
  "version",
  "sources",
  "tasks",
  "masters",
  "unlocks"
 ],
 "additionalProperties": false,
 "properties": {
  "version": {
   "type": "integer",
   "minimum": 1
  },
  "sources": {
   "type": "object"
  },
  "tasks": {
   "type": "array",
   "minItems": 120,
   "items": {
    "type": "object",
    "required": [
     "name",
     "targets",
     "icon"
    ],
    "additionalProperties": false,
    "properties": {
     "name": {
      "type": "string",
      "minLength": 1
     },
     "icon": {
      "type": "integer",
      "minimum": 0
     },
     "targets": {
      "type": "array",
      "items": {
       "type": "string"
      }
     },
     "finisher": {
      "type": "object",
      "required": [
       "itemId",
       "threshold"
      ],
      "additionalProperties": false,
      "properties": {
       "itemId": {
        "type": "integer",
        "minimum": 0
       },
       "threshold": {
        "type": "integer",
        "minimum": 0
       }
      }
     },
     "reqs": {
      "type": "array",
      "minItems": 1,
      "items": {
       "type": "string",
       "minLength": 1
      }
     },
     "stats": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
       "level": {
        "type": "number"
       },
       "hp": {
        "type": "number"
       },
       "maxHit": {
        "type": "number"
       },
       "attackStyle": {
        "type": "string"
       },
       "attackSpeed": {
        "type": "number"
       },
       "defStab": {
        "type": "number"
       },
       "defSlash": {
        "type": "number"
       },
       "defCrush": {
        "type": "number"
       },
       "defMagic": {
        "type": "number"
       },
       "defRanged": {
        "type": "number"
       },
       "weakness": {
        "type": "string"
       },
       "weaknessPercent": {
        "type": "number"
       },
       "slayerLevel": {
        "type": "number"
       },
       "slayerXp": {
        "type": "number"
       },
       "attributes": {
        "type": "array",
        "items": {
         "type": "string"
        }
       },
       "cannonImmune": {
        "type": "boolean"
       },
       "poisonous": {
        "type": "boolean"
       }
      }
     },
     "locations": {
      "type": "array",
      "items": {
       "type": "object",
       "required": [
        "name"
       ],
       "additionalProperties": false,
       "properties": {
        "name": {
         "type": "string",
         "minLength": 1
        },
        "x": {
         "type": "integer"
        },
        "y": {
         "type": "integer"
        },
        "plane": {
         "type": "integer",
         "minimum": 0,
         "maximum": 3
        },
        "reqs": {
         "type": "array",
         "minItems": 1,
         "items": {
          "type": "string",
          "minLength": 1
         }
        }
       }
      }
     },
     "bring": {
      "type": "array",
      "items": {
       "type": "object",
       "required": [
        "name",
        "required"
       ],
       "additionalProperties": false,
       "properties": {
        "name": {
         "type": "string",
         "minLength": 1
        },
        "required": {
         "type": "boolean"
        },
        "id": {
         "type": "integer",
         "minimum": 0
        }
       }
      }
     },
     "turael": {
      "type": "object",
      "required": [
       "point",
       "locations"
      ],
      "additionalProperties": false,
      "properties": {
       "point": {
        "type": "array",
        "minItems": 3,
        "maxItems": 3,
        "items": {
         "type": "integer"
        }
       },
       "note": {
        "type": "string"
       },
       "locations": {
        "type": "array",
        "minItems": 1,
        "items": {
         "type": "object",
         "required": [
          "name",
          "teleports",
          "areas"
         ],
         "additionalProperties": false,
         "properties": {
          "name": {
           "type": "string",
           "minLength": 1
          },
          "teleports": {
           "type": "array",
           "items": {
            "type": "string"
           }
          },
          "areas": {
           "type": "array",
           "items": {
            "type": "array",
            "minItems": 5,
            "maxItems": 5,
            "items": {
             "type": "integer"
            }
           }
          }
         }
        }
       }
      }
     }
    }
   }
  },
  "masters": {
   "type": "array",
   "minItems": 9,
   "maxItems": 9,
   "items": {
    "type": "object",
    "required": [
     "name",
     "focusId",
     "x",
     "y",
     "plane",
     "points",
     "wilderness",
     "tasks"
    ],
    "additionalProperties": false,
    "properties": {
     "name": {
      "type": "string",
      "minLength": 1
     },
     "focusId": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9
     },
     "x": {
      "type": "integer"
     },
     "y": {
      "type": "integer"
     },
     "plane": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3
     },
     "points": {
      "type": "integer",
      "minimum": 0
     },
     "wilderness": {
      "type": "boolean"
     },
     "reqs": {
      "type": "array",
      "minItems": 1,
      "items": {
       "type": "string",
       "minLength": 1
      }
     },
     "aliases": {
      "type": "array",
      "items": {
       "type": "string"
      }
     },
     "tasks": {
      "type": "array",
      "minItems": 15,
      "items": {
       "type": "object",
       "required": [
        "task",
        "weight"
       ],
       "additionalProperties": false,
       "properties": {
        "task": {
         "type": "string",
         "minLength": 1
        },
        "weight": {
         "type": "integer",
         "minimum": 1
        },
        "amount": {
         "type": "string"
        },
        "extended": {
         "type": "string"
        },
        "reqs": {
         "type": "array",
         "minItems": 1,
         "items": {
          "type": "string",
          "minLength": 1
         }
        },
        "locations": {
         "type": "array",
         "items": {
          "type": "string"
         }
        }
       }
      }
     }
    }
   }
  },
  "unlocks": {
   "type": "array",
   "minItems": 30,
   "items": {
    "type": "object",
    "required": [
     "key",
     "name",
     "points",
     "varbit",
     "category"
    ],
    "additionalProperties": false,
    "properties": {
     "key": {
      "type": "string",
      "pattern": "^slayerreward_[a-z0-9]+$"
     },
     "name": {
      "type": "string",
      "minLength": 1
     },
     "points": {
      "type": "integer",
      "minimum": 0
     },
     "varbit": {
      "type": "string",
      "pattern": "^SLAYER_[A-Z0-9_]+$"
     },
     "category": {
      "enum": [
       "unlock",
       "extend"
      ]
     },
     "desc": {
      "type": "string"
     },
     "icon": {
      "type": "string",
      "pattern": "^[a-z0-9]+\\.png$"
     }
    }
   }
  }
 }
}
