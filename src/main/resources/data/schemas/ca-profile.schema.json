{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Combat Profile arithmetic (cs2-sourced player vars)",
	"type": "object",
	"required": ["source", "generated", "excludedTopIndex", "tasksCompletedVarbits",
		"bossKillCountVarps", "skillingKillCountVarps", "raidCompletionVarps", "killVarps"],
	"additionalProperties": false,
	"properties": {
		"source": {
			"type": "string"
		},
		"generated": {
			"type": "string",
			"pattern": "^\\d{4}-\\d{2}-\\d{2}$"
		},
		"excludedTopIndex": {
			"type": "integer",
			"minimum": 0
		},
		"tasksCompletedVarbits": {
			"type": "array",
			"minItems": 6,
			"maxItems": 6,
			"items": {
				"type": "integer",
				"minimum": 1
			}
		},
		"bossKillCountVarps": {
			"type": "array",
			"minItems": 20,
			"items": {
				"type": "integer",
				"minimum": 1
			}
		},
		"skillingKillCountVarps": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "integer",
				"minimum": 1
			}
		},
		"raidCompletionVarps": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "integer",
				"minimum": 1
			}
		},
		"killVarps": {
			"type": "object",
			"minProperties": 30,
			"propertyNames": {
				"pattern": "^\\d+$"
			},
			"additionalProperties": {
				"type": "array",
				"minItems": 1,
				"items": {
					"type": "integer",
					"minimum": 1
				}
			}
		}
	}
}
