{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Iron Hub emote clue item requirements (starter set)",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "clues"],
  "properties": {
    "$schema": {"type": "string"},
    "version": {"type": "integer", "minimum": 1},
    "clues": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["tier", "clue", "requirements"],
        "properties": {
          "tier": {"enum": ["Beginner", "Easy", "Medium", "Hard", "Elite", "Master"]},
          "clue": {"type": "string", "minLength": 1},
          "requirements": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}
