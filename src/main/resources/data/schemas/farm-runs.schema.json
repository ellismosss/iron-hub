{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Farm-run stops and teleport options (from Easy Farming, BSD-2)",
	"type": "object",
	"required": [
		"source",
		"generated",
		"locations"
	],
	"additionalProperties": false,
	"properties": {
		"source": {
			"type": "string"
		},
		"generated": {
			"type": "string",
			"pattern": "^\\d{4}-\\d{2}-\\d{2}$"
		},
		"locations": {
			"type": "array",
			"minItems": 20,
			"items": {
				"type": "object",
				"required": [
					"id",
					"category",
					"name",
					"point",
					"reqs",
					"teleports"
				],
				"additionalProperties": false,
				"properties": {
					"id": {
						"type": "string",
						"pattern": "^(herb|tree|fruit|hops)/[a-z0-9-]+$"
					},
					"reqs": {
						"type": "array",
						"items": {
							"type": "string",
							"pattern": "^(skill|quest|queststarted|diary):"
						}
					},
					"category": {
						"enum": [
							"herb",
							"tree",
							"fruit",
							"hops"
						]
					},
					"name": {
						"type": "string",
						"minLength": 1
					},
					"point": {
						"type": "object",
						"required": [
							"x",
							"y",
							"plane"
						],
						"additionalProperties": false,
						"properties": {
							"x": {
								"type": "integer"
							},
							"y": {
								"type": "integer"
							},
							"plane": {
								"type": "integer",
								"minimum": 0,
								"maximum": 3
							}
						}
					},
					"teleports": {
						"type": "array",
						"minItems": 1,
						"items": {
							"type": "object",
							"required": [
								"id",
								"category",
								"description",
								"supplier",
								"items"
							],
							"additionalProperties": false,
							"properties": {
								"id": {
									"type": "string",
									"minLength": 1
								},
								"category": {
									"enum": [
										"ITEM",
										"PORTAL_NEXUS",
										"SPIRIT_TREE",
										"FAIRY_RING",
										"JEWELLERY_BOX",
										"MOUNTED_XERICS",
										"SPELLBOOK",
										"NONE"
									]
								},
								"description": {
									"type": "string",
									"minLength": 1
								},
								"supplier": {
									"type": [
										"string",
										"null"
									],
									"enum": [
										"house",
										"fairyRing",
										null
									]
								},
								"items": {
									"type": "array",
									"items": {
										"type": "object",
										"required": [
											"itemId",
											"qty"
										],
										"additionalProperties": false,
										"properties": {
											"itemId": {
												"type": "integer",
												"minimum": 1
											},
											"qty": {
												"type": "integer",
												"minimum": 1
											}
										}
									}
								}
							}
						}
					}
				}
			}
		}
	}
}
